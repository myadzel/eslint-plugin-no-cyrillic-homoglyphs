{
  "name": "eslint-plugin-no-cyrillic-homoglyphs",
  "version": "1.0.1",
  "description": "ESLint plugin to replace cyrillic characters with their visual ASCII equivalents",
  "author": "Alexander Myadzel",
  "license": "MIT",
  "main": "dist/index.js",
  "keywords": [
    "eslint",
    "eslintplugin",
    "cyrillic",
    "homoglyph",
    "ascii",
    "lint"
  ],
  "scripts": {
    "build": "rimraf dist && babel src --out-dir dist --copy-files",
    "prepare": "npm run build"
  },
  "files": [
    "dist"
  ],
  "devDependencies": {
    "@babel/cli": "^7.28.6",
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.5.5",
    "babel-plugin-add-module-exports": "^1.0.4",
    "rimraf": "^6.1.3"
  },
  "directories": {
    "lib": "lib"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/myadzel/eslint-plugin-no-cyrillic-homoglyphs.git"
  },
  "bugs": {
    "url": "https://github.com/myadzel/eslint-plugin-no-cyrillic-homoglyphs/issues"
  },
  "homepage": "https://github.com/myadzel/eslint-plugin-no-cyrillic-homoglyphs#readme"
}
